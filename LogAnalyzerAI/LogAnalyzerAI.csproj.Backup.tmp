<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.7.0" />
    <PackageReference Include="Microsoft.Extensions.AI.Ollama" Version="9.0.0-preview.9.24507.7" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="OpenAI">
      <HintPath>..\..\..\openai-dotnet\OpenAI\src\bin\Debug\net10.0\OpenAI.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
